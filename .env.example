# ============================================================================
# SPITE — environment variable template
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — it will never be committed.
# After editing, restart the app for changes to take effect.
# ============================================================================

# --- Database (Neon Postgres) -----------------------------------------------
# Where: neon.tech → your project → "Connection string"
# Must start with postgresql://
DATABASE_URL=""

# --- Cloudflare R2 storage --------------------------------------------------
# Where: dash.cloudflare.com → R2 → API tokens
# Account ID from the right sidebar of any R2 page.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# The R2 bucket name you created. Anything you like.
R2_BUCKET_NAME=""

# Leave EMPTY for the default secure setup. Uploads are served through the
# /api/r2-image proxy with HMAC-signed URLs — the bucket stays private.
# Only set this if you've connected a custom public domain to the bucket.
R2_PUBLIC_URL=""

# --- fal.ai (AI generation provider) ----------------------------------------
# Where: fal.ai → Dashboard → Keys
# Format: <uuid>:<hex>
FAL_KEY=""

# --- App login --------------------------------------------------------------
# The password you'll type at the SPITE login screen.
# Choose something strong — this is the only thing between the internet and
# your canvas. App will refuse to boot if this is empty.
APP_PASSWORD=""

# --- Optional ---------------------------------------------------------------
# Used by the scheduled cleanup job at /api/assets/cleanup. Only needed if
# you've wired up a cron (Vercel Cron, GitHub Actions, etc.) to call that
# route. Any long random string works.
CRON_SECRET=""

# Public base URL of your deployment, used when SPITE generates signed
# reference URLs to send to fal.ai. Only needed if you're hosting outside
# Vercel — on Vercel, SPITE automatically uses VERCEL_PROJECT_PRODUCTION_URL
# so fal can fetch references through your public production URL even when
# you're testing on a Deployment-Protected preview. Set this if you have a
# custom domain or non-Vercel host.
# Format: https://your-domain.com  (no trailing slash)
# SITE_URL=""

# Optional kill switch. Set to "1" to refuse all new generation submissions
# from the canvas — useful if you suspect a runaway billing situation.
# Leave unset or empty for normal operation.
# GENERATION_DISABLED=""

# Optional per-hour USD ceiling enforced server-side on generation
# submissions. Default $100/hour — fits a working AI-filmmaker session
# with room for video batches while still capping a runaway loop or
# compromised cookie at a bounded loss. Raise for unusual projects, set
# to 0 to disable entirely.
# SPEND_LIMIT_USD_PER_HOUR=""

# Optional HMAC signing secret for the /api/r2-image proxy. Falls back to
# APP_PASSWORD if not set, which is fine for single-user. Set a distinct
# value if you want to be able to rotate APP_PASSWORD without invalidating
# every previously-signed asset URL.
# R2_PROXY_SIGNING_SECRET=""
